[
  {
    "label": "Debug Game",
    "adapter": "godot",
    "request": "launch",
    "project": "$ZED_WORKTREE_ROOT",
    "platform": "host",
    "scene": "main",
    "build": "build-without-tests"
  },
  {
    "label": "Debug Current Scene",
    "adapter": "godot",
    "request": "launch",
    "project": "$ZED_WORKTREE_ROOT",
    "platform": "host",
    "scene": "current",
    "build": "build-without-tests"
  },
  {
    "label": "Debug Tests",
    "adapter": "godot",
    "request": "launch",
    "project": "$ZED_WORKTREE_ROOT",
    "platform": "host",
    "scene": "main",
    "playArgs": [
      "--run-tests",
      "--quit-on-finish"
    ],
    "build": "build"
  },
  {
    "label": "Debug Current Test",
    "adapter": "godot",
    "request": "launch",
    "project": "$ZED_WORKTREE_ROOT",
    "platform": "host",
    "scene": "main",
    "playArgs": [
      "--run-tests=${ZED_STEM:CurrentTestName}",
      "--quit-on-finish"
    ],
    "build": "build"
  }
]
